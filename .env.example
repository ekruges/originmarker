# Copy to .env beside docker-compose.yml, fill in what you want, `chmod 600 .env`.
# .env is gitignored and dockerignored: it is read by `docker compose up` on the host
# and injected as process env at runtime. It never enters the image or the browser.
#
# ALL OF THESE ARE OPTIONAL. With none set, OriginMarker is fully functional:
# rsID/HGVS search, panel builds, every export. You lose only free-text NL search
# and the optional LD annotation.

# Enables the free-text search box ("markers near the ABCC8 splice mutation").
# Any rsID/HGVS input bypasses the LLM entirely, so this is only billed for prose
# that names no identifier. Haiku, temperature 0, capped output, cached prompt.
ANTHROPIC_API_KEY=

# Enables the optional LD annotation between two common SNPs. Free token from
# https://ldlink.nih.gov/?tab=apiaccess
LDLINK_TOKEN=

# Raises the NCBI E-utilities rate limit (3/s -> 10/s). Free from your NCBI account.
NCBI_API_KEY=
NCBI_CONTACT_EMAIL=
