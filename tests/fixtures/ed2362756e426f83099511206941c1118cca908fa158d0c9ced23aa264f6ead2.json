              </Name>
              <Name>
                <ElementValue Type="Alternate">HOMOCYSTEINURIA DUE TO MTHFR DEFICIENCY</ElementValue>
                <XRef Type="Allelic variant" ID="607093.0010" DB="OMIM"/>
              </Name>
